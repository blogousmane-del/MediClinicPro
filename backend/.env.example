PORT=5000
JWT_SECRET=your-random-jwt-secret-key-here
NODE_ENV=development

# Supabase Configurations
# Replaces SQLite with a Supabase PostgreSQL instance
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_KEY_HERE

# SMTP Configurations (Optional, falls back to console logs if blank)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MediClinic Pro" <no-reply@mediclinic.ci>
